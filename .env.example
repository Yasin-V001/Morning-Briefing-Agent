APP_NAME=morning-briefing-agent
APP_ENV=development
TIMEZONE=America/Denver

GOOGLE_CLIENT_SECRET_FILE=/root/openclaw_project/credentials/google_client_secret.json
GOOGLE_TOKEN_FILE=/root/openclaw_project/credentials/google_token.json

WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LATITUDE=39.7392
WEATHER_LONGITUDE=-104.9903

OPENCLAW_ENABLED=false
OPENCLAW_DELIVERY_MODE=stdout
OPENCLAW_CHANNEL=
OPENCLAW_RECIPIENT=

DATABASE_URL=sqlite:////root/openclaw_project/data/app.db